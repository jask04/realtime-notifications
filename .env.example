# Copy this file to .env and fill in values.
# For local dev, the defaults below match docker-compose.yml.

# Postgres connection string. Matches the user/password/db in docker-compose.yml.
DATABASE_URL=postgresql://notifications:dev@localhost:5432/notifications

# Redis connection string. Used later for the BullMQ job queue and rate limiting.
REDIS_URL=redis://localhost:6379

# Secret used to sign and verify JWTs. Use a long random string in production.
JWT_SECRET=change-me-in-prod-but-fine-for-dev

# Port the HTTP server listens on.
PORT=3000

# One of: development | test | production
NODE_ENV=development

# SMTP credentials for outbound email. In dev we use Mailtrap's sandbox
# inbox (https://mailtrap.io) so emails are captured instead of delivered;
# in production these would point at SES, SendGrid, Postmark, etc.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password

# "From" address on outbound emails. Should be a domain you control in prod.
SMTP_FROM=notifications@example.com
